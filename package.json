{
  "name": "penny-wallet",
  "version": "1.0.0",
  "description": "Personal finance tracker Obsidian plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs development",
    "dev:watch": "node esbuild.config.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "demo:data": "node scripts/generate-demo-data.mjs",
    "build": "node esbuild.config.mjs production",
    "build:dev": "node esbuild.config.mjs development",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit --pretty",
    "lint:fix": "eslint \"src/**/*.ts\" --fix && tsc --noEmit --pretty",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "twrusstw",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.24.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^16.0.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.29.0",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.2"
  }
}
